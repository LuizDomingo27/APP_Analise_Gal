# Exemplo de secrets do Streamlit — COPIE para .streamlit/secrets.toml e preencha.
# O arquivo real (.streamlit/secrets.toml) está no .gitignore e NUNCA deve ser commitado.
#
# Como obter a DATABASE_URL:
#   1. app.supabase.com → seu projeto → botão "Connect"
#      (ou Project Settings → Database → Connection string)
#   2. Aba "Transaction pooler" (porta 6543)
#   3. Troque [YOUR-PASSWORD] pela senha do banco
#   4. Adicione "+psycopg2" logo após "postgresql"
#   5. Se a senha tiver caracteres especiais (@ : / ? # % &), faça URL-encode
#      (ex.: @ -> %40, # -> %23)

DATABASE_URL = "postgresql+psycopg2://postgres.SEU_REF:SUA_SENHA@aws-0-SUA_REGIAO.pooler.supabase.com:6543/postgres"

# Secrets antigos do sync com GitHub — serão removidos na Fase 3 (não mais usados).
# GITHUB_TOKEN = "..."
# GITHUB_REPO  = "usuario/repositorio"
